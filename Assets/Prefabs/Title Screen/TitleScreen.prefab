      m_Calls: []
  m_text: 'Objective: Defend your beacon from the invading zombies\n\nGame Mechanics:\n>
    Zombie waves spawn every 30 seconds\n> Each wave has more zombies\n> More zombies
    spawn in a lane each time the disrutor is destroyed\n\nGameplay:\n> Kill zombies
    to collect money\n> Spend money on items and stat upgrades in th shop\n> Collect
    power ups for temporary stat boosts\n\nControls:\n> WASD to move \n> Space to
    jump \n> Left click to use / attack\n> Scroll Wheel / Num keys 1-5 to switch
    items\n> E to interact\n> Tab to open map\n> ESC to open menu

'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
